# Copy this file to .env before starting Docker Compose.
SYNCWATCH_VIEWER_PASSWORD=replace-with-viewer-password
SYNCWATCH_ADMIN_PASSWORD=replace-with-a-different-admin-password
SYNCWATCH_JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Optional deployment settings.
SYNCWATCH_TAG=latest
SYNCWATCH_PORT=8080
TZ=Asia/Shanghai
